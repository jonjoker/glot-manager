{
  "name": "@glot-manager/core",
  "version": "0.1.0",
  "description": "Framework-agnostic core for Glot Manager: types, ICU/placeholder validation, glossary- and context-aware prompt building, and the Translator/Store interfaces.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "glot-manager-dev": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --test \"test/*.test.ts\""
  },
  "keywords": [
    "i18n",
    "l10n",
    "translation",
    "icu",
    "glossary",
    "localization"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonjoker/glot-manager.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  }
}
